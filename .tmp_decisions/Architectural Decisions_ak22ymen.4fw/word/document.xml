acing"/><w:rPr><w:rFonts w:ascii="Amiri" w:hAnsi="Amiri" w:cs="Amiri"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr></w:pPr><w:r w:rsidRPr="00281A47"><w:rPr><w:rFonts w:ascii="Amiri" w:hAnsi="Amiri" w:cs="Amiri"/><w:b/><w:bCs/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr><w:t>Chosen Decision:</w:t></w:r><w:r w:rsidRPr="00281A47"><w:rPr><w:rFonts w:ascii="Amiri" w:hAnsi="Amiri" w:cs="Amiri"/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr><w:br/></w:r><w:r w:rsidR="00162CED"><w:rPr><w:rFonts w:ascii="Amiri" w:hAnsi="Amiri" w:cs="Amiri"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:rtl/></w:rPr><w:tab/></w:r><w:r w:rsidR="00162CED" w:rsidRPr="00281A47"><w:rPr><w:rFonts w:ascii="Amiri" w:hAnsi="Amiri" w:cs="Amiri"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t>Store the AI draft in Redis with TTL.</w:t></w:r></w:p><w:p w14:paraId="7FB8B3FB" w14:textId="5DCBCD16" w:rsidR="00162CED" w:rsidRPr="0010453E" w:rsidRDefault="00162CED" w:rsidP="0010453E"><w:pPr><w:pStyle w:val="NoSpacing"/><w:ind w:left="720"/><w:rPr><w:rFonts w:ascii="Amiri" w:hAnsi="Amiri" w:cs="Amiri"/><w:sz w:val="24"/><w:szCs w:val="24"/><w:rtl/></w:rPr></w:pPr><w:r w:rsidRPr="0010453E"><w:rPr><w:rFonts w:ascii="Amiri" w:hAnsi="Amiri" w:cs="Amiri"/><w:b/><w:bCs/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t>Justification:</w:t></w:r><w:r w:rsidRPr="0010453E"><w:rPr><w:rFonts w:ascii="Amiri" w:hAnsi="Amiri" w:cs="Amiri"/><w:b/><w:bCs/><w:sz w:val="24"/><w:szCs w:val="24"/><w:rtl/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidRPr="0010453E"><w:rPr><w:rFonts w:ascii="Amiri" w:hAnsi="Amiri" w:cs="Amiri"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t>Redis provides fast, reliable, and temporary storage for AI drafts, supporting partial regeneration and interactive editing while automatically cleaning up expired drafts. Django sessions are limited for large or complex data, and in-memory storage is not reliable for production systems.</w:t></w:r></w:p><w:p w14:paraId="62A90D2B" w14:textId=